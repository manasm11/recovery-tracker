# Backend configuration. Copy to .env and adjust for your environment.

# Database. Defaults to a local SQLite file. For production use Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./recovery.db

# Auth — CHANGE THESE in production.
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Seed accounts created on first startup.
SEED_USERNAME=employee
SEED_PASSWORD=changeme123
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme123

# CORS: comma-separated allowed origins, or * for all.
CORS_ORIGINS=*
